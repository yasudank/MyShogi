# Build
## Android
/build
!*/build/classes
/capture*
/local.properties

## IntelliJ
.idea
.gradle
/capture
*.iml
*.ipr
*.iws
/.idea
/libraries
/external

## Android Studio
/sync

# Built application files
## Java
*.class
*.jar
*.war
*.ear

# Gradle
# Allow the gradle directory itself so we can un-ignore files within it
!/gradle/
# Ignore everything inside gradle by default
/gradle/*
# Un-ignore the version catalog and the wrapper
!/gradle/libs.versions.toml
!/gradle/wrapper/
/gradlew
/gradlew.bat

# Log files
*.log

# Android Profiling
*.hprof

# Keystore files
# Exclude keystore files from version control
*.jks
*.keystore
*.p12

# External native build folder generated in Android Studio 2.2 and later.
/externalNativeBuild
.cxx
# Command line .json file generated for Skylark Gradle build graph in Android Studio 2.3 and 3.0
cxx-flags.json
